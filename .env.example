# Application Configuration
APP_NAME=Restaurant Reservation System
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# Database Configuration
# For SQLite (async): sqlite+aiosqlite:///reservation_system.db
# For PostgreSQL (async): postgresql+asyncpg://user:password@localhost/dbname
DATABASE_URL=sqlite+aiosqlite:///reservation_system.db
SQL_ECHO=false

# API Configuration
API_V1_PREFIX=/api/v1

# Restaurant Hours (24-hour format)
RESTAURANT_HOURS_START=10
RESTAURANT_HOURS_END=22
